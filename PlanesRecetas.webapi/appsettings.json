{
  "ApplicationName": "ms-plans",
  "EnnableSecurity": false,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki:3100",
          "labels": [
            {
              "key": "app",
              "value": "planesrecetas.api"
            },
            {
              "key": "env",
              "value": "production"
            }
          ],
          "propertiesAsLabels": [ "app", "env" ]
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]

  },
  "AllowedHosts": "*",
  "DataBaseSettings": {
    "ConnectionString": "Host=localhost;Port=5432;Database=appservice;Username=postgres;Password=Password12345;"
  },
  "RabbitMqSettings": {
    "Host": "localhost",
    "Port": 5672,
    "UserName": "admin",
    "Password": "admin",
    "QueueName": "plan-created",
    "VirtualHost": "/"
  },
  "JwtOptions": {
    "Lifetime": 30,
    "Secret": "",
    "Audience": "*",
    "ValidIssuer": "",
    "ValidateAudience": true,
    "ValidateIssuer": true,
    "ValidateLifetime": true,
    "ExpiryMinutes": 480
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "JaegerSettings": {
    "Host": "localhost",
    "Port": 6831
  },
  "Consul": {
    "Host": "http://localhost:8500",
    "ServiceName": "ms-plans",
    "ServiceAddress": "localhost",
    "ServicePort": 1700,
    "Tags": [
      "dotnet",
      "api",
      "ms-plans",
      "metrics"
    ],
    "HealthCheckEndpoint": "/health/live"
  }
}
